#!/usr/bin/env bash
# setup — single entry point for claw infrastructure
#
# Config & runtime state: ~/.claw/config/   (persists across git pulls)
# Repo config/ dir:       factory defaults, copied on first run
#
# Usage:
#   ./setup server                      # M2 Ultra inference server
#   ./setup client <server-host>        # Mac or Linux client
#   ./setup client                      # (reads ~/.claw/config/connection.env)
#   ./setup status                      # What's installed
#   ./setup uninstall                   # Remove symlinks and services

set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
CLAW_HOME="$HOME/.claw"
CLAW_CONFIG="$CLAW_HOME/config"
ROLE="${1:-}"
shift 2>/dev/null || true

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'
info()  { echo -e "${CYAN}[INFO]${NC}  $*"; }
ok()    { echo -e "${GREEN}[OK]${NC}    $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
err()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }

# Copy repo defaults → ~/.claw/config/ (never overwrites)
bootstrap_config() {
  mkdir -p "$CLAW_CONFIG"
  for f in "$REPO_DIR"/config/*; do
    [[ -f "$f" ]] || continue
    local base="$(basename "$f")"
    [[ "$base" == *.example ]] && continue
    if [[ ! -f "$CLAW_CONFIG/$base" ]]; then
      cp "$f" "$CLAW_CONFIG/$base"
      info "Installed default → ~/.claw/config/$base"
    fi
  done
}

usage() {
  cat <<'EOF'
Usage: ./setup <role> [options]

Roles:
  server                  oMLX inference server (M2 Ultra)
  client [server-host]    claw CLI client (Mac or Linux)
  status                  Show what's installed
  uninstall               Remove symlinks and services

All config:  ~/.claw/config/
All runtime: ~/.claw/
EOF
}

case "$ROLE" in
  server)
    bootstrap_config
    exec "$REPO_DIR/server/install.sh" "$REPO_DIR" "$@"
    ;;
  client)
    bootstrap_config
    exec "$REPO_DIR/client/install.sh" "$REPO_DIR" "$@"
    ;;
  status)
    echo -e "\n${BOLD}Claw infrastructure status${NC}"
    echo "  Repo:   $REPO_DIR"
    echo "  Home:   $CLAW_HOME"
    echo "  Config: $CLAW_CONFIG"
    echo ""

    if [[ -f "$CLAW_HOME/settings.json" ]]; then
      PORT=$(python3 -c "import json; print(json.load(open('$CLAW_HOME/settings.json'))['port'])" 2>/dev/null || echo "?")
      API_KEY=""
      [[ -f "$CLAW_HOME/api_key" ]] && API_KEY="$(cat "$CLAW_HOME/api_key")"
      AUTH_HEADER=""
      [[ -n "$API_KEY" ]] && AUTH_HEADER="Authorization: Bearer ${API_KEY}"
      if curl -sf ${AUTH_HEADER:+-H "$AUTH_HEADER"} "http://localhost:${PORT}/v1/models" >/dev/null 2>&1; then
        ok "oMLX server running :${PORT}"
        curl -s ${AUTH_HEADER:+-H "$AUTH_HEADER"} "http://localhost:${PORT}/v1/models" 2>/dev/null \
          | python3 -c "import json,sys
for m in json.load(sys.stdin).get('data',[]): print(f'         • {m[\"id\"]}')" 2>/dev/null
      else
        warn "oMLX configured but not responding :${PORT}"
      fi
    else
      info "No server on this machine"
    fi

    [[ -L "$HOME/.claw-env" ]] && ok "Client env: ~/.claw-env → $(readlink "$HOME/.claw-env")" \
      || info "No client env linked"
    [[ -L "$HOME/.local/bin/claw" ]] && ok "Binary: → $(readlink "$HOME/.local/bin/claw")" \
      || command -v claw &>/dev/null && ok "Binary: $(command -v claw)" \
      || info "claw binary not found"

    PLIST="$HOME/Library/LaunchAgents/com.claw.omlx-server.plist"
    [[ -L "$PLIST" ]] && ok "launchd: → $(readlink "$PLIST")"
    echo ""
    ;;

  uninstall)
    echo -e "\n${BOLD}Uninstalling claw${NC}"
    PLIST="$HOME/Library/LaunchAgents/com.claw.omlx-server.plist"
    [[ -f "$PLIST" || -L "$PLIST" ]] && { launchctl unload "$PLIST" 2>/dev/null || true; rm -f "$PLIST"; ok "Removed launchd service"; }
    for f in "$HOME/.claw-env" "$HOME/.local/bin/claw"; do
      [[ -L "$f" ]] && { rm -f "$f"; ok "Removed $f"; }
    done
    info "~/.claw/ left in place — remove manually if desired."
    ok "Done"
    ;;

  ""|--help|-h) usage; exit 0 ;;
  *) err "Unknown role: $ROLE"; usage; exit 1 ;;
esac
