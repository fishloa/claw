#!/usr/bin/env bash
# setup — single entry point for claw infrastructure
#
# Clone this repo on any machine, run ./setup, done.
# Later: git pull to get updates — everything is linked back here.
#
# Usage:
#   ./setup server                      # M2 Ultra inference server
#   ./setup client <server-host>        # Mac or Linux client
#   ./setup client                      # (reads server host from config/connection.env)
#   ./setup status                      # Check what's installed
#   ./setup uninstall                   # Remove symlinks and services
#
# The repo directory becomes the single source of truth.
# All installed artefacts are symlinks or source-references back to this tree.

set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
ROLE="${1:-}"
shift 2>/dev/null || true

# ── Colours ──────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

info()  { echo -e "${CYAN}[INFO]${NC}  $*"; }
ok()    { echo -e "${GREEN}[OK]${NC}    $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
err()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }
header(){ echo -e "\n${BOLD}$*${NC}"; }

usage() {
  cat <<EOF
Usage: ./setup <role> [options]

Roles:
  server                  Set up this machine as the oMLX inference server
  client [server-host]    Set up this machine as a claw CLI client
  status                  Show what's installed and linked
  uninstall               Remove all symlinks and services

Examples:
  ./setup server
  ./setup client mac-studio.local
  ./setup client 192.168.1.50
  ./setup status
EOF
}

case "$ROLE" in
  server)
    exec "$REPO_DIR/server/install.sh" "$REPO_DIR" "$@"
    ;;
  client)
    exec "$REPO_DIR/client/install.sh" "$REPO_DIR" "$@"
    ;;
  status)
    header "Claw infrastructure status"
    echo "  Repo:     $REPO_DIR"
    echo ""

    # Check server
    if [[ -f "$HOME/.omlx/settings.json" ]]; then
      OMLX_PORT=$(python3 -c "import json; print(json.load(open('$HOME/.omlx/settings.json'))['port'])" 2>/dev/null || echo "?")
      if curl -sf "http://localhost:${OMLX_PORT}/v1/models" >/dev/null 2>&1; then
        ok "oMLX server running on port $OMLX_PORT"
        curl -s "http://localhost:${OMLX_PORT}/v1/models" 2>/dev/null \
          | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    for m in data.get('data', []):
        print(f'         • {m[\"id\"]}')
except: pass
" 2>/dev/null
      else
        warn "oMLX configured but not responding on port $OMLX_PORT"
      fi
    else
      info "No server configured on this machine"
    fi

    # Check client
    if [[ -L "$HOME/.claw-env" ]]; then
      TARGET="$(readlink "$HOME/.claw-env")"
      if [[ -f "$TARGET" ]]; then
        ok "Client env linked: ~/.claw-env → $TARGET"
      else
        warn "Client env symlink broken: ~/.claw-env → $TARGET"
      fi
    elif [[ -f "$HOME/.claw-env" ]]; then
      warn "Client env exists but is a plain file (not linked to repo)"
    else
      info "No client configured on this machine"
    fi

    # Check claw binary
    if [[ -L "$HOME/.local/bin/claw" ]]; then
      ok "claw binary linked: ~/.local/bin/claw → $(readlink "$HOME/.local/bin/claw")"
    elif command -v claw &>/dev/null; then
      ok "claw binary found: $(command -v claw)"
    else
      info "claw binary not installed"
    fi

    # Check launchd (macOS)
    PLIST="$HOME/Library/LaunchAgents/com.claw.omlx-server.plist"
    if [[ -L "$PLIST" ]]; then
      ok "launchd plist linked: $PLIST → $(readlink "$PLIST")"
    elif [[ -f "$PLIST" ]]; then
      warn "launchd plist exists but is a plain file (not linked to repo)"
    fi
    ;;

  uninstall)
    header "Uninstalling claw infrastructure"

    # Stop and unload launchd service
    PLIST="$HOME/Library/LaunchAgents/com.claw.omlx-server.plist"
    if [[ -f "$PLIST" ]] || [[ -L "$PLIST" ]]; then
      launchctl unload "$PLIST" 2>/dev/null || true
      rm -f "$PLIST"
      ok "Removed launchd service"
    fi

    # Remove symlinks
    for f in "$HOME/.claw-env" "$HOME/.local/bin/claw"; do
      if [[ -L "$f" ]]; then
        rm -f "$f"
        ok "Removed $f"
      fi
    done

    info "Shell profile entries (~/.zshrc etc.) left in place — remove manually if desired."
    info "Models in ~/models/mlx and ~/.omlx/ left in place — remove manually if desired."
    ok "Done"
    ;;

  ""|--help|-h)
    usage
    exit 0
    ;;

  *)
    err "Unknown role: $ROLE"
    usage
    exit 1
    ;;
esac
