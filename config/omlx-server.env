# config/omlx-server.env — server defaults (checked into git)
# Secrets (API key) are generated at install time, never committed.

# ── Network ──────────────────────────────────────────────────────────
OMLX_HOST="0.0.0.0"
OMLX_PORT="10741"

# ── Model storage ────────────────────────────────────────────────────
OMLX_MODEL_DIR="$HOME/models/mlx"

# ── Memory budget (M2 Ultra 128 GB) ─────────────────────────────────
OMLX_MAX_PROCESS_MEMORY="85%"
OMLX_MAX_MODEL_MEMORY="96GB"

# ── KV cache ─────────────────────────────────────────────────────────
OMLX_SSD_CACHE_DIR="$HOME/.omlx/cache"
OMLX_HOT_CACHE_MAX_SIZE="8GB"

# ── Concurrency ──────────────────────────────────────────────────────
OMLX_MAX_NUM_SEQS="8"

# ── Default model ────────────────────────────────────────────────────
OMLX_DEFAULT_MODEL="gemma-4-31b-it-8bit"
