# config/connection.env — generated by ./setup server
# Contains server IP, port, and API key for clients.
# This file is gitignored. Copy it manually to client clones,
# or pass values as args:  ./setup client <host> <port> <key>
#
# CLAW_SERVER_HOST="192.168.1.50"
# CLAW_SERVER_PORT="10741"
# CLAW_API_KEY="claw-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# CLAW_DEFAULT_MODEL="Qwen3-Coder-Next-4bit"
